generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model alerts {
  id                                  String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  alert_type                          alert_type
  status                              alert_status  @default(OPEN)
  case_id                             String?       @db.Uuid
  person_id                           String?       @db.Uuid
  cctv_log_id                         String?       @db.Uuid
  camera_id                           String?       @db.Uuid
  confidence                          Float?        @db.Real
  message                             String
  created_at                          DateTime?     @default(now()) @db.Timestamptz(6)
  acknowledged_by                     String?       @db.Uuid
  acknowledged_at                     DateTime?     @db.Timestamptz(6)
  resolved_by                         String?       @db.Uuid
  resolved_at                         DateTime?     @db.Timestamptz(6)
  users_alerts_acknowledged_byTousers users?        @relation("alerts_acknowledged_byTousers", fields: [acknowledged_by], references: [id], onUpdate: NoAction)
  cctv_cameras                        cctv_cameras? @relation(fields: [camera_id], references: [id], onUpdate: NoAction)
  cases                               cases?        @relation(fields: [case_id], references: [id], onUpdate: NoAction)
  cctv_logs                           cctv_logs?    @relation(fields: [cctv_log_id], references: [id], onUpdate: NoAction)
  case_person                         case_person?  @relation(fields: [person_id], references: [id], onUpdate: NoAction)
  users_alerts_resolved_byTousers     users?        @relation("alerts_resolved_byTousers", fields: [resolved_by], references: [id], onUpdate: NoAction)

  @@index([case_id], map: "idx_alerts_case")
  @@index([created_at(sort: Desc)], map: "idx_alerts_created")
  @@index([person_id], map: "idx_alerts_person")
  @@index([status], map: "idx_alerts_status")
  @@index([alert_type], map: "idx_alerts_type")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model case_person {
  id                   String               @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  case_id              String               @db.Uuid
  category             person_category
  full_name            String?
  alias                String?
  gender               person_gender?       @default(UNKNOWN)
  age                  Int?
  height_cm            Int?
  weight_kg            Int?
  skin_tone            String?
  eye_color            String?
  hair_color           String?
  last_known_clothing  String?
  distinguishing_marks String?
  description          String?
  is_primary           Boolean              @default(true)
  created_at           DateTime?            @default(now()) @db.Timestamptz(6)
  updated_at           DateTime?            @default(now()) @db.Timestamptz(6)
  alerts               alerts[]
  cases                cases                @relation(fields: [case_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  case_person_photos   case_person_photos[]
  cctv_logs            cctv_logs[]
  face_embeddings      face_embeddings[]
  sketch_searches      sketch_searches[]

  @@index([case_id], map: "idx_case_person_case")
  @@index([category], map: "idx_case_person_category")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model case_person_photos {
  id                                                                     String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  case_person_id                                                         String?           @db.Uuid
  uploaded_by                                                            String?           @db.Uuid
  source                                                                 photo_source
  file_path                                                              String
  file_hash                                                              String?           @unique
  status                                                                 photo_status      @default(UPLOADED)
  is_primary                                                             Boolean?          @default(false)
  face_detected                                                          Boolean?          @default(false)
  face_quality_score                                                     Float?            @db.Real
  embedding_generated                                                    Boolean?          @default(false)
  approved_by                                                            String?           @db.Uuid
  approved_at                                                            DateTime?         @db.Timestamptz(6)
  created_at                                                             DateTime?         @default(now()) @db.Timestamptz(6)
  updated_at                                                             DateTime?         @default(now()) @db.Timestamptz(6)
  image_type                                                             image_type        @default(PHOTO)
  users_case_person_photos_approved_byTousers                            users?            @relation("case_person_photos_approved_byTousers", fields: [approved_by], references: [id], onUpdate: NoAction)
  case_person                                                            case_person?      @relation(fields: [case_person_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users_case_person_photos_uploaded_byTousers                            users?            @relation("case_person_photos_uploaded_byTousers", fields: [uploaded_by], references: [id], onUpdate: NoAction)
  face_embeddings                                                        face_embeddings[]
  sketch_searches_sketch_searches_candidate_photo_idTocase_person_photos sketch_searches[] @relation("sketch_searches_candidate_photo_idTocase_person_photos")
  sketch_searches_sketch_searches_sketch_photo_idTocase_person_photos    sketch_searches[] @relation("sketch_searches_sketch_photo_idTocase_person_photos")

  @@index([embedding_generated], map: "idx_case_person_photos_embedding")
  @@index([case_person_id], map: "idx_case_person_photos_person")
  @@index([status], map: "idx_case_person_photos_status")
}

model cases {
  id                                String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  case_number                       String?           @unique
  case_type                         case_type
  status                            case_status       @default(SUBMITTED)
  title                             String
  description                       String?
  created_by                        String            @db.Uuid
  assigned_admin                    String?           @db.Uuid
  assigned_at                       DateTime?         @db.Timestamptz(6)
  last_seen_location                String?
  last_seen_time                    DateTime?         @db.Timestamptz(6)
  is_active                         Boolean           @default(true)
  created_at                        DateTime?         @default(now()) @db.Timestamptz(6)
  updated_at                        DateTime?         @default(now()) @db.Timestamptz(6)
  rejection_reason                  String?
  withdraw_reason                   String?
  withdraw_requested_at             DateTime?         @db.Timestamptz(6)
  alerts                            alerts[]
  case_person                       case_person[]
  users_cases_assigned_adminTousers users?            @relation("cases_assigned_adminTousers", fields: [assigned_admin], references: [id], onUpdate: NoAction)
  users_cases_created_byTousers     users             @relation("cases_created_byTousers", fields: [created_by], references: [id], onUpdate: NoAction)
  complainants                      complainants?
  sketch_searches                   sketch_searches[]

  @@index([assigned_admin], map: "idx_cases_assigned_admin")
  @@index([created_by], map: "idx_cases_created_by")
  @@index([status], map: "idx_cases_status")
  @@index([case_type], map: "idx_cases_type")
}

model cctv_cameras {
  id                   String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  camera_code          String        @unique
  camera_name          String?
  camera_type          camera_type   @default(FIXED)
  status               camera_status @default(ACTIVE)
  location_description String?
  latitude             Float?
  longitude            Float?
  ip_address           String?
  stream_url           String?
  installed_by         String?       @db.Uuid
  installed_at         DateTime?     @db.Timestamptz(6)
  created_at           DateTime?     @default(now()) @db.Timestamptz(6)
  updated_at           DateTime?     @default(now()) @db.Timestamptz(6)
  alerts               alerts[]
  users                users?        @relation(fields: [installed_by], references: [id], onUpdate: NoAction)
  cctv_logs            cctv_logs[]

  @@index([latitude, longitude], map: "idx_cctv_location")
  @@index([status], map: "idx_cctv_status")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model cctv_logs {
  id                 String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  camera_id          String           @db.Uuid
  detected_person_id String?          @db.Uuid
  detection_status   detection_status
  confidence         Float?           @db.Real
  bbox_x1            Int
  bbox_y1            Int
  bbox_x2            Int
  bbox_y2            Int
  snapshot_path      String?
  model_name         String
  model_version      String
  detected_at        DateTime         @default(now()) @db.Timestamptz(6)
  reviewed_by        String?          @db.Uuid
  reviewed_at        DateTime?        @db.Timestamptz(6)
  notes              String?
  alerts             alerts[]
  cctv_cameras       cctv_cameras     @relation(fields: [camera_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  case_person        case_person?     @relation(fields: [detected_person_id], references: [id], onUpdate: NoAction)
  users              users?           @relation(fields: [reviewed_by], references: [id], onUpdate: NoAction)

  @@index([camera_id], map: "idx_cctv_logs_camera")
  @@index([detected_person_id], map: "idx_cctv_logs_person")
  @@index([detection_status], map: "idx_cctv_logs_status")
  @@index([detected_at(sort: Desc)], map: "idx_cctv_logs_time")
}

model face_embeddings {
  id                 String                @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  case_person_id     String                @db.Uuid
  photo_id           String                @db.Uuid
  embedding          Unsupported("vector")
  model_name         String
  model_version      String
  embedding_status   embedding_status      @default(ACTIVE)
  created_at         DateTime?             @default(now()) @db.Timestamptz(6)
  case_person        case_person           @relation(fields: [case_person_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  case_person_photos case_person_photos    @relation(fields: [photo_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([photo_id, model_name, model_version], map: "unique_embedding_per_photo_model")
  @@index([embedding], map: "face_embeddings_vector_idx")
  @@index([case_person_id], map: "idx_face_embeddings_person")
  @@index([embedding_status], map: "idx_face_embeddings_status")
}

model users {
  id                                                       String               @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  role                                                     user_role            @default(USER)
  full_name                                                String
  email                                                    String               @unique
  phone                                                    String?              @unique
  password_hash                                            String
  is_active                                                Boolean              @default(true)
  is_verified                                              Boolean              @default(false)
  created_at                                               DateTime?            @default(now()) @db.Timestamptz(6)
  updated_at                                               DateTime?            @default(now()) @db.Timestamptz(6)
  alerts_alerts_acknowledged_byTousers                     alerts[]             @relation("alerts_acknowledged_byTousers")
  alerts_alerts_resolved_byTousers                         alerts[]             @relation("alerts_resolved_byTousers")
  case_person_photos_case_person_photos_approved_byTousers case_person_photos[] @relation("case_person_photos_approved_byTousers")
  case_person_photos_case_person_photos_uploaded_byTousers case_person_photos[] @relation("case_person_photos_uploaded_byTousers")
  cases_cases_assigned_adminTousers                        cases[]              @relation("cases_assigned_adminTousers")
  cases_cases_created_byTousers                            cases[]              @relation("cases_created_byTousers")
  cctv_cameras                                             cctv_cameras[]
  cctv_logs                                                cctv_logs[]
  refresh_tokens                                           refresh_tokens[]
  sketch_searches                                          sketch_searches[]

  @@index([email], map: "idx_users_email")
  @@index([role], map: "idx_users_role")
}

model refresh_tokens {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id    String   @db.Uuid
  token_hash String
  expires_at DateTime @db.Timestamptz(6)
  revoked    Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([token_hash], map: "idx_refresh_tokens_token_hash")
  @@index([user_id], map: "idx_refresh_tokens_user_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model sketch_searches {
  id                                                                        String             @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  sketch_photo_id                                                           String             @db.Uuid
  candidate_person_id                                                       String             @db.Uuid
  candidate_photo_id                                                        String             @db.Uuid
  similarity_score                                                          Float              @db.Real
  decision                                                                  detection_status
  performed_by                                                              String             @db.Uuid
  case_id                                                                   String             @db.Uuid
  model_name                                                                String
  model_version                                                             String
  created_at                                                                DateTime?          @default(now()) @db.Timestamptz(6)
  case_person                                                               case_person        @relation(fields: [candidate_person_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_candidate_person")
  case_person_photos_sketch_searches_candidate_photo_idTocase_person_photos case_person_photos @relation("sketch_searches_candidate_photo_idTocase_person_photos", fields: [candidate_photo_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_candidate_photo")
  case_person_photos_sketch_searches_sketch_photo_idTocase_person_photos    case_person_photos @relation("sketch_searches_sketch_photo_idTocase_person_photos", fields: [sketch_photo_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_sketch_photo")
  cases                                                                     cases              @relation(fields: [case_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_sketch_search_case")
  users                                                                     users              @relation(fields: [performed_by], references: [id], onUpdate: NoAction, map: "fk_sketch_search_user")

  @@index([case_id], map: "idx_sketch_searches_case")
  @@index([decision], map: "idx_sketch_searches_decision")
  @@index([sketch_photo_id], map: "idx_sketch_searches_sketch")
  @@index([created_at(sort: Desc)], map: "idx_sketch_searches_time")
}

model complainants {
  id         String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  case_id    String    @unique @db.Uuid
  full_name  String
  phone      String
  email      String?
  gender     String
  age        Int
  relation   String
  aadhaar    String
  address    String
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  updated_at DateTime? @default(now()) @db.Timestamptz(6)
  cases      cases     @relation(fields: [case_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_complainant_case")

  @@index([case_id], map: "idx_complainants_case_id")
}

enum alert_status {
  OPEN
  ACKNOWLEDGED
  RESOLVED
  DISMISSED
}

enum alert_type {
  CCTV_MATCH
  CASE_UPDATE
  SYSTEM
}

enum camera_status {
  ACTIVE
  DISABLED
  MAINTENANCE
}

enum camera_type {
  FIXED
  PTZ
  MOBILE
  DRONE
}

enum case_status {
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  WITHDRAWN
  CLOSED
  WITHDRAW_REQUESTED
  DRAFT
}

enum case_type {
  MISSING
  WANTED
}

enum detection_status {
  UNKNOWN
  POSSIBLE
  CONFIRMED
  FALSE_POSITIVE
  REVIEWED
}

enum embedding_status {
  ACTIVE
  REVOKED
  DEPRECATED
}

enum person_category {
  MISSING
  WANTED
}

enum person_gender {
  MALE
  FEMALE
  OTHER
  UNKNOWN
}

enum photo_source {
  USER_UPLOAD
  ADMIN_UPLOAD
  CCTV_FRAME
  SYSTEM_GENERATED
}

enum photo_status {
  UPLOADED
  APPROVED
  REJECTED
  ARCHIVED
}

enum user_role {
  USER
  ADMIN
  SUPER_ADMIN
}

enum image_type {
  PHOTO
  SKETCH
}

enum person_type {
  MISSING
  WANTED
}
